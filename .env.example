# ==========================================
# Ethiopian P2P USDT Marketplace Config
# ==========================================

# 1. Database Connection (PostgreSQL)
# Used by Prisma to perform migrations and run queries
DATABASE_URL="postgresql://postgres:securepassword123@localhost:5432/ethiopian_p2p?schema=public"

# 2. Supabase Settings (Auth and Storage)
# Get these from your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 3. Tatum Blockchain API (TRON TRC20 Escrow Wallets)
# Create a free API key on Tatum Dashboard (tatum.io)
TATUM_API_KEY="tatum-api-key-here"
TATUM_WEBHOOK_SECRET="your-webhook-signature-secret"

# 4. Sumsub KYC Integration (Identity Compliance)
# Retrieve these credentials from Sumsub developer sandbox dashboard
SUMSUB_API_TOKEN="sumsub-api-token-here"
SUMSUB_SECRET_KEY="sumsub-secret-key-here"
SUMSUB_WEBHOOK_SECRET="sumsub-webhook-secret-here"

# 5. Admin Configuration
# Comma-separated list of email addresses that have administrative rights
ADMIN_EMAILS="admin@ethiopianp2p.com,admin@p2p.com"

# 6. Compliance Provider settings (SUMSUB, VERIFF, PERSONA)
KYC_PROVIDER="SUMSUB"
